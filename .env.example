# Example environment configuration for Secondsight.
#
# Copy this file to `.env` and adjust the values for your machine:
#   cp .env.example .env
#
# These variables are read by the scripts and the Gradio app as fallbacks when
# the corresponding command-line flags are not provided. Never commit your
# real `.env` file (it is git-ignored).

# Absolute path to the Market-1501 dataset root. This should point to the
# directory that contains `bounding_box_train/`, `query/`, and
# `bounding_box_test/` (typically `.../Market-1501-v15.09.15`).
# Obtain it by running: python scripts/download_data.py
REID_DATA_ROOT=

# Path to the trained model checkpoint (`.pth`) used by the evaluation script
# and the Gradio demo. If unset or missing, the demo falls back to a
# randomly-initialized model so it still launches.
REID_WEIGHTS=outputs/best.pth
